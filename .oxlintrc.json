{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["eslint", "typescript", "unicorn", "oxc", "vue"],
	"env": {
		"browser": true
	},
	"categories": {
		"correctness": "error"
	},
	"rules": {
		"no-unused-vars": [
			"error",
			{
				"vars": "all",
				"args": "after-used",
				"ignoreRestSiblings": false
			}
		],
		"no-unused-imports": "error"
	}
}
